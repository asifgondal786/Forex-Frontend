# Frontend runtime env template (local only).
# Do not commit real secrets to Frontend/.env.
# For production Flutter Web, prefer --dart-define / CI environment variables.

# Canonical frontend URL
APP_WEB_URL=https://forexcompanion-e5a28.web.app

# Backend API endpoint (Railway). Must be HTTPS in production.
API_BASE_URL=https://forex-backend-production-bc44.up.railway.app

# Firebase web config (Auth + database related operations)
FIREBASE_API_KEY=replace_with_firebase_api_key
FIREBASE_AUTH_DOMAIN=forexcompanion-e5a28.firebaseapp.com
FIREBASE_DATABASE_URL=replace_with_database_url_if_used
FIREBASE_PROJECT_ID=forexcompanion-e5a28
FIREBASE_STORAGE_BUCKET=forexcompanion-e5a28.appspot.com
FIREBASE_MESSAGING_SENDER_ID=replace_with_sender_id
FIREBASE_APP_ID=replace_with_app_id
FIREBASE_MEASUREMENT_ID=replace_if_used
